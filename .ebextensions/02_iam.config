# .ebextensions/02_iam.config
# Grants the EC2 instance profile permission to call DynamoDB, S3, SNS.
# Attach this policy to the aws-elasticbeanstalk-ec2-role in IAM instead
# if you prefer not to use ebextensions for IAM.
#
# NOTE: The recommended approach is to attach a managed or inline policy
# directly to the EB instance role in the IAM console (see docs/ebs_deploy.md).
# This file is provided as a reference only.

Resources:
  IMHMInstancePolicy:
    Type: AWS::IAM::Policy
    Properties:
      PolicyName: IMHM-InstancePolicy
      PolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: Allow
            Action:
              - dynamodb:PutItem
              - dynamodb:GetItem
              - dynamodb:Query
              - dynamodb:Scan
              - dynamodb:UpdateItem
            Resource:
              - !Sub "arn:aws:dynamodb:${AWS::Region}:${AWS::AccountId}:table/MachineLatestStatus"
              - !Sub "arn:aws:dynamodb:${AWS::Region}:${AWS::AccountId}:table/MachineHistory"
          - Effect: Allow
            Action:
              - s3:PutObject
              - s3:GetObject
            Resource: !Sub "arn:aws:s3:::${S3_BUCKET_NAME}/*"
          - Effect: Allow
            Action:
              - sns:Publish
            Resource: "*"
      Roles:
        - aws-elasticbeanstalk-ec2-role
