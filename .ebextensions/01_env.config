# .ebextensions/01_env.config
# Elastic Beanstalk — inject environment variables into the container.
# These are read from the EB environment, NOT from .env file on disk.
# Set actual values via:
#   eb setenv IOT_ENDPOINT=xxx SNS_TOPIC_ARN=xxx ...
# or in the AWS Console under Configuration → Software.

option_settings:
  aws:elasticbeanstalk:application:environment:
    PYTHONUNBUFFERED: "1"
    FLASK_DEBUG: "false"
    FLASK_PORT: "5000"
    # The values below are placeholders — override them with `eb setenv`
    AWS_REGION: "eu-west-1"
    DYNAMO_LATEST_TABLE: "MachineLatestStatus"
    DYNAMO_HISTORY_TABLE: "MachineHistory"
    ENABLE_S3_ARCHIVE: "true"
